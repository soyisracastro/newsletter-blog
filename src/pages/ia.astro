---
import Layout from '../layouts/Layout.astro';
import { PUBLIC_SENDY_ACTION_URL, PUBLIC_SENDY_API_KEY, PUBLIC_SENDY_EBOOK_LIST_ID } from 'astro:env/client';

const NAS_IO_URL = 'https://nas.io/columna13/products/ia-para-contadores';
const PRICE = '$297 MXN';
const PRICE_BUNDLE = '$597 MXN';

const actionUrl = PUBLIC_SENDY_ACTION_URL;
const ebookListId = PUBLIC_SENDY_EBOOK_LIST_ID;
const formId = 'ebook-lead-form';
---

<Layout
  title="IA para Contadores — Lo que nadie te explicó sobre la herramienta más poderosa de tu despacho"
  description="Ebook gratuito para contadores mexicanos: entiende la inteligencia artificial sin código, sin tecnicismos y con ejemplos del SAT, CFDI e ISR. Descarga los primeros 2 capítulos."
  image="/og/ebook/ia-para-contadores.png"
>
  <main class="max-w-2xl mx-auto px-6 pb-24 pt-16">

    <!-- Hero -->
    <div class="flex flex-col gap-4 py-2 md:py-4">
      <p class="text-neutral-500 text-sm font-mono uppercase tracking-widest text-center">Ebook para contadores</p>
      <h1 class="tape-title text-4xl md:text-5xl mx-auto text-center leading-tight">
        IA para Contadores
      </h1>
      <p class="text-neutral-500 text-xl italic leading-relaxed text-center mt-2">
        Lo que nadie te explicó sobre la herramienta<br class="hidden md:block" /> más poderosa de tu despacho.
      </p>
      <p class="text-neutral-400 text-sm text-center mt-1 font-mono">
        Isca Castro · TodoConta
      </p>
    </div>

    <!-- Propuesta -->
    <div class="mt-12 flex flex-col gap-5 text-lg leading-relaxed text-neutral-800">
      <p>La IA ya está cambiando cómo trabajan los despachos. El problema es que nadie te la explica en términos que tengan sentido para un contador.</p>
      <p>Los tutoriales de YouTube te enseñan a darle clic a botones. Este libro te enseña <strong>cómo piensan los modelos</strong>, para que puedas usar bien cualquier herramienta que salga mañana.</p>
      <ul class="list-none flex flex-col gap-2 pl-0 mt-2">
        <li>— Qué es un LLM y por qué eso te importa como contador.</li>
        <li>— Cómo darle instrucciones que dan resultados reales en el despacho.</li>
        <li>— Qué riesgos legales y profesionales trae usar IA sin entenderla.</li>
        <li>— Qué puedes automatizar hoy y qué sigue siendo tuyo como profesionista.</li>
      </ul>
    </div>

    <!-- Lo que está adentro -->
    <div class="mt-12 flex flex-col gap-2 text-base leading-relaxed text-neutral-600 border-l-2 border-neutral-200 pl-5">
      <p class="font-semibold text-neutral-800">17 capítulos + 3 apéndices.</p>
      <p>Desmitificar la IA · Entender cómo funciona por dentro · Aprender a hablarle bien · Los riesgos que nadie explica · El panorama real para tu despacho.</p>
    </div>

    <!-- Form de captura -->
    <div id="form-section" class="mt-14 pt-10 border-t border-neutral-200">
      <h2 class="text-2xl font-serif font-semibold mb-2">Lee los primeros 2 capítulos gratis.</h2>
      <p class="text-neutral-500 text-base mb-8">
        Deja tu email y te los mando de inmediato.
      </p>

      <form id={formId} action={actionUrl} method="POST" accept-charset="utf-8" class="flex flex-col gap-6">
        <div id="form-fields-ebook" class="space-y-6">
          <label class="flex flex-col w-full">
            <p class="text-neutral-800 text-base font-semibold leading-normal pb-3 px-1">Tu mejor email</p>
            <input
              name="email"
              id="email-ebook"
              class="form-input flex w-full rounded-sm text-neutral-800 focus:outline-0 focus:ring-2 focus:ring-neutral-400 border border-neutral-200 bg-white h-16 px-5 text-lg font-normal placeholder:text-neutral-400"
              placeholder="ejemplo@correo.com"
              required
              type="email"
            />
          </label>

          <div class="hidden">
            <input type="hidden" name="list" value={ebookListId} />
            <input type="hidden" name="subscribesubmit" value="true" />
            <input type="hidden" name="boolean" value="true" />
            <div style="display:none;">
              <label for="hp-ebook">HP</label><br/>
              <input type="text" name="hp" id="hp-ebook" />
            </div>
          </div>

          <label class="flex items-center gap-3 px-1 cursor-pointer">
            <input class="form-checkbox size-5 rounded-sm border-neutral-200 text-neutral-800 focus:ring-neutral-400" required type="checkbox"/>
            <span class="text-sm text-neutral-500">
              Acepto recibir emails y la <a href="/privacidad" class="underline hover:text-neutral-800 transition">política de privacidad</a>.
            </span>
          </label>
        </div>

        <button
          id="submit-btn-ebook"
          class="tape-title w-full flex cursor-pointer items-center justify-center overflow-hidden rounded-sm h-16 px-8 text-xl leading-normal shadow-lg transition-transform active:scale-[0.98]"
          type="submit"
        >
          QUIERO LOS 2 CAPÍTULOS GRATIS
        </button>

        <div id="message-ebook" class="hidden text-sm font-medium p-6 rounded-sm text-center"></div>
      </form>
    </div>

    <!-- Separador: comprar el libro completo -->
    <div class="mt-20 pt-10 border-t border-neutral-200 flex flex-col gap-6">
      <div>
        <p class="text-neutral-500 text-sm mb-1">¿Prefieres el libro completo?</p>
        <h2 class="text-2xl font-serif font-semibold">Cómpralo en nas.io</h2>
      </div>
      <p class="text-neutral-600 text-base leading-relaxed">
        Incluye descarga en PDF, versión Kindle y acceso a la versión web completa con los 17 capítulos y 3 apéndices. También disponible en bundle con el Pack de 25 Prompts para Contadores.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href={NAS_IO_URL}
          target="_blank"
          rel="noopener"
          class="tape-title flex items-center justify-center px-8 h-14 text-lg rounded-sm shadow-lg transition-transform active:scale-[0.98] text-center"
        >
          Ebook PDF — {PRICE}
        </a>
        <a
          href={NAS_IO_URL}
          target="_blank"
          rel="noopener"
          class="flex items-center justify-center px-8 h-14 text-lg border border-neutral-200 rounded-sm text-neutral-700 hover:border-neutral-400 transition text-center"
        >
          Bundle + Prompts — {PRICE_BUNDLE}
        </a>
      </div>
      <p class="text-neutral-400 text-xs">Garantía de devolución de 7 días. Sin preguntas.</p>
    </div>

    <!-- Sobre el autor -->
    <div class="mt-16 pt-10 border-t border-neutral-200">
      <h2 class="text-xl font-serif font-semibold mb-3">Sobre el autor</h2>
      <p class="text-neutral-600 text-base leading-relaxed">
        Isca Castro es contador público mexicano y programador. Dirige S&amp;I Castro Consultores bajo la marca TodoConta y escribe <a href="/" class="underline hover:text-neutral-900 transition">Columna 13</a>, un newsletter diario para contadores que quieren trabajar mejor. Este libro nació de su newsletter — la respuesta fue tan grande que decidió expandirlo y publicarlo.
      </p>
    </div>

  </main>
</Layout>

<script define:vars={{ formId, actionUrl, apiKey: PUBLIC_SENDY_API_KEY }}>
  const SUCCESS_HTML = `
    <div class="flex flex-col gap-6 py-4">
      <h2 class="font-serif text-2xl font-semibold text-neutral-800">Casi listo. Falta un paso.</h2>
      <p class="text-base text-neutral-700 leading-relaxed">
        Te mandé un email de confirmación. Ve a tu bandeja (o spam) y busca:
      </p>
      <div class="p-5 bg-neutral-50 border border-neutral-200 rounded-sm font-sans">
        <p class="text-neutral-800 text-base font-medium">Confirma que eres tú (y no un bot aburrido)</p>
      </div>
      <p class="text-sm text-neutral-500 leading-relaxed">
        Una vez confirmado, te mando los dos primeros capítulos directamente a tu correo.
      </p>
    </div>
  `;

  const setupForm = () => {
    const form = document.getElementById(formId);
    if (!form) return;

    const messageDiv = document.getElementById('message-ebook');
    const submitBtn = document.getElementById('submit-btn-ebook');
    const formFields = document.getElementById('form-fields-ebook');
    const originalBtnContent = submitBtn?.innerHTML;

    if (!messageDiv || !submitBtn || !formFields) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      messageDiv.classList.add('hidden');

      const formData = new FormData(form);
      const data = new URLSearchParams();
      for (const [key, value] of formData.entries()) {
        data.append(key, value.toString());
      }
      data.append('api_key', apiKey);
      data.append('boolean', 'true');

      submitBtn.disabled = true;
      submitBtn.innerHTML = 'Enviando...';

      try {
        const response = await fetch(actionUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: data,
        });
        const result = await response.text();

        if (result === '1') {
          formFields.innerHTML = SUCCESS_HTML;
          submitBtn.classList.add('hidden');
          window.scrollTo({ top: document.getElementById('form-section').offsetTop - 20, behavior: 'smooth' });
        } else if (result === 'Already subscribed.') {
          messageDiv.classList.remove('hidden');
          messageDiv.className = 'text-sm font-medium p-4 rounded-sm text-center bg-neutral-100 text-neutral-800 border border-neutral-200';
          messageDiv.textContent = '¡Ya estás en la lista! Revisa tu correo para los capítulos.';
        } else {
          messageDiv.classList.remove('hidden');
          messageDiv.className = 'text-sm font-medium p-4 rounded-sm text-center bg-red-50 text-red-800 border border-red-200';
          messageDiv.textContent = `Algo salió mal: ${result}`;
        }
      } catch {
        messageDiv.classList.remove('hidden');
        messageDiv.className = 'text-sm font-medium p-4 rounded-sm text-center bg-red-50 text-red-800 border border-red-200';
        messageDiv.textContent = 'Error de conexión. Inténtalo de nuevo.';
      } finally {
        if (!submitBtn.classList.contains('hidden')) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalBtnContent;
        }
      }
    });
  };

  setupForm();
  document.addEventListener('astro:page-load', setupForm);
</script>
